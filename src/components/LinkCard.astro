---
import type { LinkItem } from "../data/links";

interface Props {
  link: LinkItem;
}

const { link } = Astro.props;
---

<a
  class="link-card"
  href={link.url}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={link.title}
>
  <i class={link.icon} aria-hidden="true"></i>
  <h3>{link.title}</h3>
</a>
